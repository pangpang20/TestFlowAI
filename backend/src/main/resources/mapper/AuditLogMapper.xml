<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.testflowai.mapper.AuditLogMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.testflowai.entity.AuditLog">
        <id column="log_id" property="logId"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="operation" property="operation"/>
        <result column="resource" property="resource"/>
        <result column="resource_id" property="resourceId"/>
        <result column="details" property="details"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="timestamp" property="timestamp"/>
        <result column="result" property="result"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted_at" property="deletedAt"/>
        <result column="deleted" property="deleted"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="deleted_by" property="deletedBy"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        log_id, user_id, username, operation, resource, resource_id, details, ip_address, timestamp, result, created_at, updated_at, deleted_at, deleted, created_by, updated_by, deleted_by
    </sql>

    <!-- 根据 ID 查询审计日志 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_audit_log
        WHERE log_id = #{logId}
    </select>

    <!-- 根据用户 ID 查询审计日志列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_audit_log
        WHERE user_id = #{userId}
        ORDER BY timestamp DESC
    </select>

    <!-- 根据时间范围查询审计日志列表 -->
    <select id="selectByTimeRange" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_audit_log
        WHERE timestamp BETWEEN #{startTime} AND #{endTime}
        ORDER BY timestamp DESC
    </select>

    <!-- 查询所有审计日志 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_audit_log
        ORDER BY timestamp DESC
    </select>

    <!-- 插入审计日志 -->
    <insert id="insert" parameterType="com.testflowai.entity.AuditLog">
        INSERT INTO t_audit_log (
            log_id, user_id, username, operation, resource, resource_id, details, ip_address, timestamp, result, created_at
        ) VALUES (
            #{logId}, #{userId}, #{username}, #{operation}, #{resource}, #{resourceId},
            #{details}, #{ipAddress}, NOW(), #{result}, NOW()
        )
    </insert>

    <!-- 根据 ID 删除审计日志 -->
    <delete id="deleteById">
        DELETE FROM t_audit_log
        WHERE log_id = #{logId}
    </delete>

    <!-- 清理指定时间之前的日志 -->
    <delete id="deleteBeforeTime">
        DELETE FROM t_audit_log
        WHERE timestamp &lt; #{beforeTime}
    </delete>

</mapper>
